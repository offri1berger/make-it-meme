{
  "name": "server",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node-pg-migrate",
    "migrate:create": "node-pg-migrate create --migrations-dir src/db/migrations --migration-file-language ts",
    "migrate:up": "node-pg-migrate up --migrations-dir src/db/migrations --envPath .env",
    "migrate:down": "node-pg-migrate down --migrations-dir src/db/migrations --envPath .env"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^24.11.1",
    "@types/pg": "^8.18.0",
    "kysely-codegen": "^0.20.0",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "@make-it-meme/shared": "workspace:*",
    "bullmq": "^5.70.4",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.0",
    "kysely": "^0.28.11",
    "nanoid": "^5.1.6",
    "node-pg-migrate": "^8.0.4",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "socket.io": "^4.8.3",
    "zod": "^4.3.6"
  }
}
